{
  "name": "@uiid/bertrand",
  "version": "0.12.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Multi-session workflow manager for Claude Code.",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "bertrand": "./dist/bertrand.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uiid-systems/bertrand.git"
  },
  "homepage": "https://github.com/uiid-systems/bertrand#readme",
  "bugs": {
    "url": "https://github.com/uiid-systems/bertrand/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "workflow",
    "session-manager",
    "tui",
    "cli"
  ],
  "author": "Adam Fratino <hello@fratino.dev>",
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@orchetron/storm": "^0.2.0",
    "drizzle-orm": "^0.44.0",
    "nanoid": "^5.1.5",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.31.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.11"
}
